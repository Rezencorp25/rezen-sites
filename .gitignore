# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*

# package-lock excluded: avoids platform-specific optional dep drift
# between local (macOS) and Cloud Build (linux). Cloud Build will
# regenerate via npm install.
package-lock.json
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example

# firebase emulator data
/.firebase-data/
/.firebase/
firebase-debug.log
firestore-debug.log
ui-debug.log

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
