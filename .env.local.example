# === Data mode (mock | real) ===
# Master switch for all external data services.
# At go-live, switch granular flags to "real" one at a time. See GO_LIVE_GUIDE.md
NEXT_PUBLIC_DATA_MODE=mock
# NEXT_PUBLIC_DATA_MODE_ANALYTICS=mock
# NEXT_PUBLIC_DATA_MODE_ADS=mock
# NEXT_PUBLIC_DATA_MODE_ADSENSE=mock
# NEXT_PUBLIC_DATA_MODE_SEO=mock

# === Anthropic (AI agents — DOC 1 prototype runs with stub if absent) ===
ANTHROPIC_API_KEY=

# === Firebase (emulator in dev, real project in DOC 3) ===
NEXT_PUBLIC_FIREBASE_API_KEY=fake-for-emulator
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=rezen-sites-dev.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=rezen-sites-dev
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=rezen-sites-dev.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:xxx
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=true

# Service account JSON for real deploys (leave empty for prototype)
FIREBASE_SERVICE_ACCOUNT_JSON=

# === Demo user (seeded into Firebase Auth emulator) ===
REZEN_DEMO_USER_EMAIL=demo@rezen.dev
REZEN_DEMO_USER_PASSWORD=rezen2026
NEXT_PUBLIC_REZEN_DEMO_USER_EMAIL=demo@rezen.dev
NEXT_PUBLIC_REZEN_DEMO_USER_PASSWORD=rezen2026
