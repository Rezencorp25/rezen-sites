{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "apphosting": {
    "backendId": "rezen-sites-preview",
    "rootDir": "/",
    "ignore": [
      "node_modules",
      ".git",
      ".next",
      ".firebase",
      ".firebase-data",
      "*.local",
      ".env*",
      "!.env.local.example"
    ]
  },
  "emulators": {
    "auth": { "port": 9099 },
    "firestore": { "port": 8080 },
    "hosting": { "port": 5000 },
    "functions": { "port": 5001 },
    "ui": { "enabled": true, "port": 4000 },
    "singleProjectMode": true
  }
}
