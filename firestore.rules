// REZEN Sites — Firestore Security Rules
//
// ⚠️ STATO IBRIDO (Sprint S0):
// - Le NUOVE collection introdotte in v.2 (audit immutabile, seo cache,
//   ai logs, rate limits, leads) hanno rules production-grade.
// - Il resto del prototipo mantiene rules aperte come da DOC 1.
// - DOC 3 / Sprint dedicato: stringere TUTTE le rules a default-deny + RBAC,
//   coerente con Compliance Playbook §3.2.

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && request.auth.token.role == 'admin';
    }

    // ── Internal collections (Admin SDK / Cloud Functions only) ────────

    // SEO data cache — popolata da Cloud Functions (DataForSEO sync).
    // Client può leggere; nessuno scrive da client.
    match /_seo_cache/{cacheId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // AI Visibility logs — popolato da multi-LLM client server-side.
    // Solo admin legge (privacy: prompt completi possono contenere dati cliente).
    match /_ai_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Rate limits — touch-only da Admin SDK con runTransaction.
    match /_rate_limits/{key} {
      allow read, write: if false;
    }

    // ── Audit (project-scoped, immutabile) ─────────────────────────────

    // Audit eventi sui leads di un progetto.
    // - read: utente autenticato (in DOC 3: solo project member)
    // - create: Admin SDK (Cloud Functions); update/delete sempre deny
    match /projects/{projectId}/leads/{leadId}/_audit/{eventId} {
      allow read: if isSignedIn();
      allow create: if false; // solo Admin SDK
      allow update, delete: if false;
    }

    // Storico audit progetto (Site Audit Lighthouse — Sprint S2)
    match /projects/{projectId}/audits/{auditId} {
      allow read: if isSignedIn();
      allow create, update: if false;
      allow delete: if false;
    }

    // Rank Tracking snapshots (Sprint S5).
    // Path: projects/{id}/rank_snapshots/{YYYY-MM-DD}__{keywordId}
    // - read: utente autenticato (in DOC 3: solo project member)
    // - write: solo Admin SDK (Cloud Function runRankTracking)
    // - TTL 90gg via Firestore TTL policy su `createdAt`.
    match /projects/{projectId}/rank_snapshots/{snapshotId} {
      allow read: if isSignedIn();
      allow create, update, delete: if false;
    }

    // Keyword set per progetto (popolato da onboarding wizard S6d).
    // Read da utente autenticato; write da utente autenticato (l'onboarding scrive
    // direttamente da client). DOC 3 stringerà a `isProjectMember(projectId)`.
    match /projects/{projectId}/seo_keywords/{keywordId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    // Competitor set per progetto (popolato da onboarding wizard S6d).
    // Letto dalla CF runGeoTracking come pool reale invece del placeholder.
    match /projects/{projectId}/competitors/{competitorId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    // Onboarding state singleton per progetto (popolato dal wizard S6d).
    // Persiste step + draft + completedAt → permette resume parziale.
    match /projects/{projectId}/onboarding/{stateId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    // GEO Tracking snapshots (Sprint S6b.3).
    // Path: projects/{id}/geo_snapshots/{YYYY-Www}__{queryId}
    // - read: utente autenticato (in DOC 3: solo project member)
    // - write: solo Admin SDK (Cloud Function runGeoTracking)
    // - TTL 365gg via Firestore TTL policy su `createdAt`.
    match /projects/{projectId}/geo_snapshots/{snapshotId} {
      allow read: if isSignedIn();
      allow create, update, delete: if false;
    }

    // AI Search Health (Sprint S6c.3).
    // Path: projects/{id}/ai_search_health/{YYYY-Www}__aish
    // - read: utente autenticato (in DOC 3: solo project member)
    // - write: solo Admin SDK (Cloud Function runAiSearchHealth)
    // - TTL 365gg via Firestore TTL policy su `checkedAt`.
    match /projects/{projectId}/ai_search_health/{snapshotId} {
      allow read: if isSignedIn();
      allow create, update, delete: if false;
    }

    // Reports PDF mensili (Sprint S8).
    // Path: projects/{id}/reports/{YYYY-MM}
    // - read: utente autenticato (in DOC 3: solo project member)
    // - write: solo Admin SDK (CF generateProjectReport / generateMonthlyReports)
    match /projects/{projectId}/reports/{reportId} {
      allow read: if isSignedIn();
      allow create, update, delete: if false;
    }

    // ── S13: Self-Service Integrations ─────────────────────────────────
    //
    // Workspace-level integrations doc.
    // Path: workspaces/{workspaceId}/integrations/{providerId}
    // - read: utente autenticato (DOC 3 stringerà a workspace member)
    // - write: solo Admin SDK (callable setIntegration / revokeIntegration)
    // Il valore reale del secret NON è qui — sta in Secret Manager (`ws-{wsId}-{provider}`).
    match /workspaces/{workspaceId}/integrations/{providerId} {
      allow read: if isSignedIn();
      allow create, update, delete: if false;
    }

    // ── Leads (Sprint S3 — Lead Pipeline interno) ──────────────────────

    // CRUD permesso a utenti autenticati.
    // DOC 3 stringerà a `isProjectMember(projectId)`.
    match /projects/{projectId}/leads/{leadId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn()
        && request.resource.data.keys().hasAll(['status', 'createdAt', 'updatedAt']);
      allow delete: if isAdmin(); // solo admin può cancellare lead
    }

    // ── S7: CMS Webflow-style ──────────────────────────────────────────
    //
    // Collezione schema (definizione collection + fields).
    // Path: projects/{projectId}/collections/{collectionId}
    // - read: utente autenticato (DOC 3 stringerà a project member)
    // - write: utente autenticato (in S7.6 si aggiungerà CF audit log on schema change)
    // L'hashId Webflow-style è dentro il documento (campo `hashId`), non nel path.
    match /projects/{projectId}/collections/{collectionId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn()
        && request.resource.data.keys().hasAll(['name', 'slug', 'fields']);
      allow delete: if isAdmin();
    }

    // CMS items (draftData + liveData + lifecycle 5-state).
    // Path: projects/{projectId}/collections/{collectionId}/items/{itemId}
    // - read: utente autenticato (DOC 3 stringerà a project member)
    // - create/update: utente autenticato; status enum: draft|queued|published|scheduled|archived
    // - delete: solo admin (preferire status='archived' come soft-delete)
    // - publish: in S7.6 una CF onWrite copierà draftData → liveData quando status passa a 'queued'
    match /projects/{projectId}/collections/{collectionId}/items/{itemId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn()
        && request.resource.data.status in ['draft', 'queued', 'published', 'scheduled', 'archived'];
      allow delete: if isAdmin();
    }

    // Item version history (popolato da CF onWrite in S7.6).
    // Path: projects/{projectId}/collections/{collectionId}/items/{itemId}/versions/{versionId}
    // - read: utente autenticato (per restore UI)
    // - write: solo Admin SDK (immutabile da client)
    match /projects/{projectId}/collections/{collectionId}/items/{itemId}/versions/{versionId} {
      allow read: if isSignedIn();
      allow create, update, delete: if false;
    }

    // ── Fallback prototipo (rules aperte) ──────────────────────────────
    //
    // ⚠️ PROTOTIPO — DOC 3 dovrà rimuovere questo fallback e stringere ogni
    // collection. Mantenuto qui solo per non rompere il prototipo esistente
    // mentre le nuove collection v.2 hanno già le rules corrette.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
